# Midas Ads Monitor — Environment Configuration
# Copy this file to .env and fill in your values
# NEVER commit .env — only .env.example

# ── Required ─────────────────────────────────────────────────────────────────
META_ACCESS_TOKEN=YOUR_META_ACCESS_TOKEN_HERE
META_API_VERSION=v21.0

# ── Storage ──────────────────────────────────────────────────────────────────
SCREENSHOTS_BASE_DIR=./screenshots
REPORTS_DIR=./reports
DB_PATH=./data/monitor.db

# ── Scheduling ───────────────────────────────────────────────────────────────
# 09:00 GST (Gulf Standard Time = UTC+4) = 05:00 UTC
CRON_SCHEDULE=0 5 * * *
SCHEDULE_MODE=MORNING_PEAK

# ── Behaviour ────────────────────────────────────────────────────────────────
MAX_RETRIES=3
RETRY_DELAY_MS=5000
SCROLL_DELAY_MS=2000
MAX_ADS_PER_COMPETITOR=50
HEADLESS=true

# ── KSA Priority clients (Facebook page names, comma-separated) ──────────────
KSA_PRIORITY_CLIENTS=IKEASaudiArabia,PanEmiratesFurniture,homecentreSA

# ── Notifications (optional) ─────────────────────────────────────────────────
SLACK_WEBHOOK_URL=

# ── Runtime ──────────────────────────────────────────────────────────────────
NODE_ENV=production
